<Page x:Class="praktika27.View.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika27.View"
      xmlns:element"clr-namespase:praktika26.View.Items"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main" FontFamily="Century Gothic">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#ff4fc318"/>
            <Setter Property="BorderBrush" Value="#ff4fc318"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>
    <Grid>
        <ListView ItemsSource="{Binding Items}" HorizontalAlignment="Stretch" Margin="0,0,0,40">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <element:Item DataContext="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
            
        </ListView>
    </Grid>
</Page>
